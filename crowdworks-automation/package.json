{
  "name": "crowdworks-automation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "setup": "tsx src/cliSetup.ts",
    "run": "tsx src/index.ts",
    "run:headful": "HEADFUL=1 tsx src/index.ts",
    "run:test": "HEADFUL=1 TEST_MODE=1 TEST_SEARCH_LIMIT=1 TEST_JOB_LIMIT=5 TEST_DRAFT_LIMIT=1 tsx src/index.ts",
    "config:check": "tsx src/cliConfig.ts check",
    "config:update": "tsx src/cliConfig.ts update",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "playwright": "^1.48.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
